# Canonical build and CI toolchain versions.
#
# Update this file first when bumping build tooling. Files that cannot source it
# directly, such as `src-tauri/rust-toolchain.toml`, `package.json`, and
# `Dockerfile`, must be kept aligned with these values.

RUST_VERSION=1.95.0
RUST_IMAGE_DIGEST=sha256:5b1e3484ddcd22a3738c0ec34a5e98bf19382eb295fb6db54295e62379119040
NODE_VERSION=24.14.0
DENO_VERSION=2.7.13
TAURI_CLI_VERSION=2.11.1

UBUNTU_RUNNER=ubuntu-22.04
WINDOWS_RUNNER=windows-2022
MACOS_RUNNER=macos-14
MACOS_TARGET=x86_64-apple-darwin

LINUX_APT_PACKAGES="libwebkit2gtk-4.1-dev libappindicator3-dev librsvg2-dev patchelf libpcap-dev"
