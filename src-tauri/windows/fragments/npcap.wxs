<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Fragment>
    <!-- Detect the WinPcap-compatible DLLs provided by Npcap. -->
    <Property Id="WPCAP_DLL_PATH">
      <DirectorySearch Id="SearchSystem64ForWpcap" Path="[System64Folder]">
        <FileSearch Id="SearchWpcapDll" Name="wpcap.dll" />
      </DirectorySearch>
    </Property>
    <Property Id="PACKET_DLL_PATH">
      <DirectorySearch Id="SearchSystem64ForPacket" Path="[System64Folder]">
        <FileSearch Id="SearchPacketDll" Name="Packet.dll" />
      </DirectorySearch>
    </Property>
  </Fragment>

  <Fragment>
    <!-- Embed the pinned Npcap installer in the MSI Binary table. -->
    <Binary Id="NpcapInstallerExe" SourceFile="$(sys.SOURCEFILEDIR)..\npcap-1.87.exe" />

    <CustomAction
      Id="CA_InstallNpcap"
      BinaryKey="NpcapInstallerExe"
      ExeCommand="/S /winpcap_mode=yes"
      Execute="deferred"
      Impersonate="no"
      Return="check"
    />
  </Fragment>

  <Fragment>
    <!-- Run Npcap only for fresh installs where WinPcap-compatible DLLs are missing. -->
    <InstallExecuteSequence>
      <Custom Action="CA_InstallNpcap" After="InstallFiles">
        ((NOT WPCAP_DLL_PATH) OR (NOT PACKET_DLL_PATH)) AND (NOT Installed)
      </Custom>
    </InstallExecuteSequence>
  </Fragment>

</Wix>
